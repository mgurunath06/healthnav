{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-tool.mjs vite",
    "dev:test": "node scripts/run-tool.mjs vite --mode test-auth",
    "build": "node scripts/run-tool.mjs vite build",
    "lint": "eslint .",
    "test": "node scripts/run-tool.mjs vitest run",
    "test:watch": "node scripts/run-tool.mjs vitest",
    "test:e2e": "playwright test",
    "test:backend": "cd ../backend && python -m unittest test_model_routing test_profile_context test_chat_responses test_investigation_depth test_investigation_stream",
    "test:all": "npm run lint && npm run test && npm run build && npm run test:backend && npm run test:e2e",
    "preview": "vite preview"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.8",
    "@phosphor-icons/react": "^2.1.10",
    "html2canvas": "^1.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.16.0",
    "uuid": "^14.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@rollup/wasm-node": "^4.53.3",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "vite": "^7.2.4",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "rollup": "npm:@rollup/wasm-node@4.53.3"
  }
}
